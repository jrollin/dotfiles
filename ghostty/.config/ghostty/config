#font-family = "Fira Code Retina"
font-family = "JetBrainsMono Nerd Font"

theme = Dracula+
# theme = TokyoNight Moon

# macos-icon = xray
#macos-titlebar-style = tabs

font-thicken = true
font-size = 14


mouse-hide-while-typing = true

# split-divider-color ="pink"
window-decoration = false
window-save-state = always

# Window settings
window-padding-x = 8
window-padding-y = 8
# background = 000000
background-opacity = 0.85
background-blur-radius = 30

# keybinds
#keybind = global:cmd+s=toggle_quick_terminal
#keybind = ctrl+h=goto_split:left
#keybind = ctrl+j=goto_split:bottom
#keybind = ctrl+k=goto_split:top
#keybind = ctrl+l=goto_split:right
#
#
#keybind = super+ctrl+h=resize_split:left,10
#keybind = super+ctrl+j=resize_split:down,10
#keybind = super+ctrl+k=resize_split:up,10
#keybind = super+ctrl+l=resize_split:right,10
#
#
# Ghostty sends correct control codes for ctrl+letter natively.
# WARNING: do NOT add explicit ctrl+key=text:\xNN keybinds here — they
# conflict with tmux extended-keys, causing double/exponential input.
# See: https://prokopov.me/posts/ghostty-remap-keys/ (not needed for tmux)

# forward cmd+s to neovim as <D-s>
keybind = cmd+s=text:\x1b[115;9u

# font size
keybind = ctrl+equal=increase_font_size:1
keybind = ctrl+shift+equal=decrease_font_size:1

