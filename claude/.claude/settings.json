{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(wc:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(test:*)",
      "Bash(git commit:*)",
      "Bash(git add:*)",
      "Bash(ls:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "Bash(find:*)",
      "Bash(docker-compose:*)",
      "Bash(docker exec:*)",
      "Bash(chmod:*)",
      "Bash(curl:*)",
      "Bash(make:*)",
      "Bash(java:*)",
      "Bash(jq:*)",
      "Bash(cartog:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git branch:*)",
      "Bash(git stash:*)",
      "Bash(git checkout:*)",
      "Bash(git rebase:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(diff:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cartog rag:*)",
      "Bash(cartog outline:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm depcruise:*)",
      "Bash(pnpm:*)"
    ],
    "ask": [
      "Bash(git push:*)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'F=$(echo \"$CLAUDE_TOOL_INPUT\" | jq -r .file_path 2>/dev/null); case \"${F##*/}\" in .env*|*.pem|*.key|*credentials*|*secret*) echo \"BLOCKED: refusing to edit sensitive file: $F\" >&2; exit 1;; esac'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/julienrollin/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'F=$CLAUDE_FILE; case \"$F\" in *.rs) cargo check --message-format=short 2>&1 | head -20;; *.ts|*.tsx|*.js|*.jsx) if [ -f \"$(git rev-parse --show-toplevel 2>/dev/null)/biome.json\" ] || [ -f \"$(git rev-parse --show-toplevel 2>/dev/null)/biome.jsonc\" ]; then biome check --write \"$F\" 2>&1 | tail -5; elif [ -f \"$(git rev-parse --show-toplevel 2>/dev/null)/.eslintrc*\" ] || [ -f \"$(git rev-parse --show-toplevel 2>/dev/null)/eslint.config*\" ]; then npx --no-install eslint --fix \"$F\" 2>&1 | tail -5; fi;; *.py) if command -v ruff &>/dev/null; then ruff check --fix \"$F\" 2>&1 | tail -5; fi;; *.rb) if [ -f \"$(git rev-parse --show-toplevel 2>/dev/null)/.rubocop.yml\" ]; then bundle exec rubocop -a \"$F\" 2>&1 | tail -5; fi;; *.sh|*.bash) if command -v shellcheck &>/dev/null; then shellcheck \"$F\" 2>&1 | tail -10; fi;; esac'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "claudio@claudio-power": true,
    "superpowers@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "sonarqube@sonar": false,
    "qa@skello-plugins": true,
    "dev@skello-plugins": true,
    "cartog@cartog-plugins": true
  },
  "extraKnownMarketplaces": {
    "claudio-power": {
      "source": {
        "source": "git",
        "url": "git@github.com:jrollin/claudio.git"
      },
      "autoUpdate": true
    },
    "cartog-plugins": {
      "source": {
        "source": "github",
        "repo": "jrollin/cartog"
      },
      "autoUpdate": true
    },
    "hashicorp": {
      "source": {
        "source": "github",
        "repo": "hashicorp/agent-skills"
      }
    },
    "sonar": {
      "source": {
        "source": "github",
        "repo": "SonarSource/sonarqube-agent-plugins"
      }
    },
    "skello-plugins": {
      "source": {
        "source": "github",
        "repo": "skelloapp/skills"
      },
      "autoUpdate": true
    }
  },
  "alwaysThinkingEnabled": false,
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754123955721
  }
}
