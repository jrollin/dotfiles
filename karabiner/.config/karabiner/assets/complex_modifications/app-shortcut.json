{
  "title": "App shortcut",
  "rules": [
    {
      "description": "Launch new Terminal",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "return_or_enter",
            "modifiers": { "mandatory": ["option"] }
          },
          "to": [
            {
              "shell_command": "osascript -e 'tell application \"Ghostty\" to activate' -e 'delay 0.05' -e 'tell application \"System Events\" to keystroke \"n\" using command down'"
            }
          ]
        }
      ]
    }
  ]
}
